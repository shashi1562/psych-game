rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth()     { return request.auth != null; }
    function isHost(rid)  {
      return isAuth() &&
        get(/databases/$(database)/documents/rooms/$(rid)).data.hostId == request.auth.uid;
    }

    match /rooms/{roomId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.hostId == request.auth.uid;
      allow update: if isAuth();   // any player can update (submissions, votes via merge)
      allow delete: if isHost(roomId);

      match /players/{playerId} {
        allow read:   if isAuth();
        allow create: if isAuth();
        allow update: if isAuth() && (request.auth.uid == playerId || isHost(roomId));
        allow delete: if isHost(roomId);
      }
    }
  }
}
